      "expected_findings_by_tool": {
        "nmap": [
          "port:8083"
        ],
        "zap": [
          "web:missing-content-security-policy",
          "web:missing-x-frame-options",
          "web:missing-x-content-type-options",
          "web:cookie-missing-secure",
          "web:cookie-missing-httponly",
          "web:cookie-missing-samesite"
        ]
      }
    },
    {
      "id": "tcp-banner-lab",
